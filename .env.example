# Copy this file to .env.local and paste your values from Supabase.
# Supabase Dashboard → Connect / API Keys

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Use one of these. Supabase's newer UI calls this value "Publishable key".
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-key

# Optional: public URL used for metadata after deployment.
# Local development can leave this as http://localhost:3000.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
